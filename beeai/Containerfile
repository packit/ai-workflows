FROM fedora:42

# Install system dependencies
RUN dnf -y install \
    python3 \
    python3-pip \
    python3-redis \
    glab \
    git \
    curl \
    rpmlint \
    rpmdevtools \
    rpmbuild \
    spectool

# Install BeeAI framework
RUN pip3 install \
    beeai-framework[mcp] \
    beeai-framework[duckduckgo] \
    openinference-instrumentation-beeai \
    arize-phoenix-otel

# Enable passwordless sudo
RUN sed -i '/NOPASSWD/s/^# //' /etc/sudoers

# Create user
RUN useradd -m -G wheel beeai

# Create directories
RUN mkdir -p /home/beeai/agents
RUN chown -R beeai:beeai /home/beeai

USER beeai
WORKDIR /home/beeai

CMD ["/bin/bash"]
