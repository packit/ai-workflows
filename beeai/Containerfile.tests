FROM fedora:42

# Install system dependencies
RUN dnf -y install \
      make \
      python3 \
      python3-copr \
      python3-flexmock \
      python3-ogr \
      python3-pip \
      python3-pytest \
      python3-pytest-asyncio \
      python3-specfile \
      python3-redis \
      python3-requests \
      python3-backoff \
    && dnf clean all

# Set PYTHONPATH so agents module can be imported
ENV PYTHONPATH=/src:$PYTHONPATH

# Install BeeAI Framework and FastMCP
RUN pip3 install --no-cache-dir beeai-framework fastmcp

WORKDIR /src
