summary: Triage agent end-to-end tests
description: |
    Runs the triage agent against mock Jira fixtures and mock CentOS Stream
    repos, validating that it produces the expected structured output.
    Requires the GITLAB_CI_TOKEN secret (injected via .testing-farm.yaml)
    for cloning internal fixture and secrets repos.

environment:
    # SAFETY: These prevent E2E tests from writing to production Jira
    DRY_RUN: "true"
    MOCK_JIRA: "true"
    LITELLM_DEBUG: ""

prepare:
  - name: Install container tooling
    how: install
    package:
      - podman
      - podman-compose
      - git
      - make

  - name: Clone git repo with Jiras and repos for mocking
    how: shell
    script: |
        set -euo pipefail
        cd $TMT_PLAN_DATA

        git clone --depth 1 \
            "https://oauth2:${GITLAB_CI_TOKEN}@gitlab.cee.redhat.com/jotnar-project/testing-jiras.git" \
            /tmp/testing-jiras

        mkdir ./mock_repos
        cp -r /tmp/testing-jiras/mock_data/* ./mock_repos/

        mkdir ./jiras
        cp -r /tmp/testing-jiras/jiras/* ./jiras

        rm -rf /tmp/testing-jiras

  - name: Fetch and set up secrets
    how: shell
    script: |
        set -euo pipefail
        cd $TMT_PLAN_DATA

        git clone --depth 1 \
            "https://oauth2:${GITLAB_CI_TOKEN}@gitlab.cee.redhat.com/jotnar-project/ci-secrets.git" \
            /tmp/ci-secrets

        mkdir -p ./.secrets
        cp /tmp/ci-secrets/beeai-agent.env ./.secrets/
        cp /tmp/ci-secrets/mcp-gateway.env ./.secrets/
        cp /tmp/ci-secrets/rhel-config.json ./.secrets/
        cp /tmp/ci-secrets/jotnar-vertex-dev.json ./.secrets/
        cp /tmp/ci-secrets/otel-collector-config.yaml ./.secrets/
        cp /tmp/ci-secrets/.env ./.secrets/
        touch ./.secrets/keytab

        rm -rf /tmp/ci-secrets

discover:
    how: shell
    tests:
      - name: triage-agent-e2e
        test: plans/run-triage.sh
        duration: 45m
        result: custom

execute:
    how: tmt
