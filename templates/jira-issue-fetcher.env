# Jira Issue Fetcher Configuration
# Copy this file to ../.secrets/jira-issue-fetcher.env and update with your values

# Required: Jira instance URL
JIRA_URL=https://redhat.atlassian.net

# Required: Jira account email for authentication
JIRA_EMAIL=your_jira_email_here

# Required: Jira API token
# Get this from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_jira_token_here

# Required: Redis connection URL
REDIS_URL=redis://localhost:6379

# Optional: Custom JQL query (override the default)
#QUERY='project=RHEL and assignee = jotnar-project'


# Optional: Enable debug logging
#LOGLEVEL=DEBUG
