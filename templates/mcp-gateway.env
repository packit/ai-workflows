# gitlab.com -> Edit profile -> Access tokens -> Add new token
# Permissions: read_user, read_repository, read_virtual_registry, write_repository, api, read_api, write_api
# write access may delete information and it should be only used in test environments.
GITLAB_TOKEN=

JIRA_URL=https://redhat.atlassian.net
# Jira account email for authentication
JIRA_EMAIL=
# Jira API token - https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=
