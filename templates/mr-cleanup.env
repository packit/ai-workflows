# gitlab.com -> Edit profile -> Access tokens -> Add new token
# Permissions: api (needed to close MRs and post notes)
GITLAB_TOKEN=

JIRA_URL=https://redhat.atlassian.net
# Jira account email for authentication
JIRA_EMAIL=
# Jira API token - https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# Optional: override bot authors to scan (comma-separated)
# Default: jotnar-bot,redhat-ymir-agent
# GITLAB_BOT_AUTHORS=rhel-se-jotnar-admin

# Optional: disable individual phases (both default to true)
# CLOSE_STALE_MRS=false
# RESET_CLOSED_MR_JIRAS=true
