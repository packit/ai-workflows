# for example gemini:gemini-2.5-pro or anthropic:claude-sonnet-4-20250514
CHAT_MODEL=gemini:gemini-2.5-pro

# API key or other credentials corresponding to the model above
# https://console.cloud.google.com/apis/credentials -> Create credentials -> API key
GEMINI_API_KEY=
#ANTHROPIC_API_KEY=

# Required: Jira instance URL
JIRA_URL=https://redhat.atlassian.net

# Required: Jira account email for authentication
JIRA_EMAIL=

# Required: Jira API token
# Get this from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# Required: testing farm API token (Bearer token)
# Get this from https://testing-farm.io/tokens/ (select the "Red Hat" ranch)
TESTING_FARM_API_TOKEN=
